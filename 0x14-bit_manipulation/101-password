#include <stdio.h>
#include <stdlib.h>

int check_password(char *password) {
    int i;
    for (i = 0; i < 3; i++) {
        if (password[i] != ('0' + i)) {
            return 0;
        }
    }
    return 1;
}

int main(int argc, char *argv[]) {
    if (argc != 2) {
        printf("Usage: %s <password>\n", argv[0]);
        return 1;
    }

    if (check_password(argv[1])) {
        printf("Congratulations!\n");
    } else {
        printf("Wrong password.\n");
    }

    return 0;
}
