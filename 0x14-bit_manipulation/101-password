#include <stdio.h>
#include <stdlib.h>

int main() {
    int password = 101;
    int input;

    printf("Enter the password: ");
    scanf("%d", &input);

    if (input == password) {
        printf("Congratulations! The password is correct.\n");
    } else {
        printf("Sorry, the password is incorrect.\n");
    }

    return 0;
}
